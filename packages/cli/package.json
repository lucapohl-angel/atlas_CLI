{
  "name": "atlas-os",
  "version": "0.1.7",
  "description": "Atlas·OS — Autonomous Teams · Lifecycle · Agents · Skills — Orchestration System for the terminal.",
  "keywords": [
    "ai",
    "agent",
    "agents",
    "cli",
    "tui",
    "llm",
    "openrouter",
    "anthropic",
    "claude",
    "openai",
    "sdd",
    "spec-driven",
    "orchestration",
    "autonomous",
    "developer-tools"
  ],
  "homepage": "https://github.com/lucapohl-angel/ATLAS_OS#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucapohl-angel/ATLAS_OS.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/lucapohl-angel/ATLAS_OS/issues"
  },
  "license": "MIT",
  "author": "Luca Pohl Angel",
  "type": "module",
  "bin": {
    "atlas": "dist/launcher.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "atlas-os-darwin-arm64": "workspace:*",
    "atlas-os-darwin-x64": "workspace:*",
    "atlas-os-linux-arm64": "workspace:*",
    "atlas-os-linux-x64": "workspace:*",
    "atlas-os-win-x64": "workspace:*",
    "playwright": "^1.49.0"
  },
  "scripts": {
    "build": "pnpm --filter @atlas/core build && rm -rf dist && tsc --noEmit -p tsconfig.build.json && node scripts/bundle.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/bin/atlas.js",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "pnpm build && pnpm test:run"
  },
  "dependencies": {
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.5",
    "yaml": "^2.8.3",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@atlas/core": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "esbuild": "^0.24.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
