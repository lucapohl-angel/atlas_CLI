{
  "name": "atlas-os-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas CLI — Your autonomous development crew. Multi-agent, hook-driven, model-agnostic.",
  "license": "MIT",
  "author": "Luca Pohl Angel",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/require-pnpm.mjs",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "typecheck": "pnpm -r typecheck",
    "lint": "node scripts/lint.mjs",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "packageManager": "pnpm@10.33.2"
}
